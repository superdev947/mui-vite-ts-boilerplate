{
  "forbid": [
    {
      "name": "no-circular",
      "severity": "warn",
      "type": "circular"
    }
  ],
  "options": {
    "doNotFollow": {
      "path": "node_modules"
    },
    "tsPreCompilationDeps": true,
    "enhancedResolveOptions": {
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".json"],
      "conditionNames": ["types", "import", "require", "node"]
    }
  }
}
